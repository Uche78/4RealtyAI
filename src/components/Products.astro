---
// Products section component
---

<section id="products" class="py-20 bg-cream-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl lg:text-5xl font-display font-bold text-charcoal-800 mb-6">
        Your AI-Powered 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-700 to-slate-600">Real Estate</span> 
        Toolkit
      </h2>
      <p class="text-xl font-serif text-charcoal-800 max-w-3xl mx-auto">
        From lead generation to client experience, our AI tools handle the heavy lifting 
        so you can focus on closing deals and building relationships.
      </p>
    </div>

    <!-- Featured Product - ShowSmart -->
    <div class="bg-gradient-to-br from-cream-200 to-cream-100 rounded-3xl p-8 lg:p-12 mb-16 border border-warm-300">
      <div class="lg:grid lg:grid-cols-2 lg:gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-green-100 text-green-800 text-sm font-sans font-medium mb-4">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Now in Beta
          </div>
          
          <h3 class="text-3xl lg:text-4xl font-display font-bold text-charcoal-800 mb-4">
            ShowSmart™
          </h3>
          
          <p class="text-lg font-serif text-charcoal-800 mb-6">
            Your always-on showing assistant that never misses a lead. Answers property questions, 
            books showings, and sends personalized property matches — all in real-time, 24/7.
          </p>
          
          <div class="space-y-3 mb-8">
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-charcoal-800 font-serif">Instant property Q&A using your website content</span>
            </div>
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-charcoal-800 font-serif">Automated showing booking and calendar integration</span>
            </div>
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-charcoal-800 font-serif">Personalized property matching and alerts</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#beta-signup" class="bg-slate-700 text-brand-primary px-6 py-3 rounded-lg font-sans font-semibold hover:bg-slate-800 transition-colors text-center">
              Join Beta (Free)
            </a>
            <a href="#demo" class="border border-slate-700 text-slate-700 px-6 py-3 rounded-lg font-sans font-semibold hover:bg-slate-700 hover:text-brand-primary transition-colors text-center">
              Watch Demo
            </a>
          </div>1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Automated showing booking and calendar integration</span>
            </div>
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Personalized property matching and alerts</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#beta-signup" class="bg-realty-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-realty-700 transition-colors text-center">
              Join Beta (Free)
            </a>
            <a href="#demo" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:border-realty-600 hover:text-realty-600 transition-colors text-center">
              Watch Demo
            </a>
          </div>
        </div>

        <div class="mt-8 lg:mt-0">
          <div class="bg-brand-primary rounded-2xl shadow-xl p-6 transform hover:scale-105 transition-transform duration-300 border border-warm-300">
            <div class="text-center mb-4">
              <span class="text-2xl font-display font-bold text-slate-700">ShowSmart™</span>
              <p class="text-warm-600 font-serif">Your always-on showing assistant</p>
            </div>
            <div class="bg-cream-100 rounded-lg p-4 space-y-2 text-sm font-serif">
              <div class="bg-slate-100 text-slate-800 p-2 rounded">👋 Hi! Interested in the 3BR on Oak St?</div>
              <div class="bg-green-100 text-green-800 p-2 rounded">✅ Yes! $485K, updated kitchen, great schools nearby. Book a showing?</div>
              <div class="bg-yellow-100 text-yellow-800 p-2 rounded">📅 Saturday 2 PM slot booked!</div>
              <div class="bg-purple-100 text-purple-800 p-2 rounded">🏠 Sending 3 similar homes that match your criteria...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Coming Soon Products -->
    <div class="text-center mb-12">
      <h3 class="text-3xl font-display font-bold text-charcoal-800 mb-4">Coming Soon</h3>
      <p class="text-lg font-serif text-charcoal-800">The complete 4RealtyAI suite launching Q2 2025</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- LeadBoost -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">LeadBoost™</h4>
        <p class="text-charcoal-800 font-serif mb-4">AI Property Listing Generator. Create high-impact listings in seconds from photos & property details.</p>
        <p class="text-sm text-slate-700 font-sans font-medium">From photos to polished listings — instantly.</p>
      </div>

      <!-- SocialSpark -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 0h10a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2z" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">SocialSpark™</h4>
        <p class="text-charcoal-800 font-serif mb-4">AI Social Media Auto-Creator. Ready-to-post content for Instagram, TikTok, and Facebook.</p>
        <p class="text-sm text-purple-600 font-sans font-medium">Daily engagement, zero effort.</p>
      </div>

      <!-- AdGenie -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">AdGenie™</h4>
        <p class="text-charcoal-800 font-serif mb-4">AI Ad Campaign Builder. Automatically creates and manages Facebook & Google property ads.</p>
        <p class="text-sm text-green-600 font-sans font-medium">Your 24/7 ad strategist.</p>
      </div>

      <!-- MarketVision -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">MarketVision™</h4>
        <p class="text-charcoal-800 font-serif mb-4">AI Neighborhood Insights. Spot hot markets with pricing trends and demand analysis.</p>
        <p class="text-sm text-orange-600 font-sans font-medium">Data-driven market domination.</p>
      </div>

      <!-- HomeMatch -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">HomeMatch™</h4>
        <p class="text-charcoal-800 font-serif mb-4">Personalized Property Alerts. AI learns buyer preferences and sends curated listings.</p>
        <p class="text-sm text-pink-600 font-sans font-medium">Your buyers, perfectly matched.</p>
      </div>

      <!-- TourCast -->
      <div class="bg-brand-primary border border-warm-300 rounded-2xl p-6 hover:shadow-lg transition-shadow duration-300">
        <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <h4 class="text-xl font-display font-semibold text-charcoal-800 mb-3">TourCast™</h4>
        <p class="text-charcoal-800 font-serif mb-4">AI Video Tours. Transform listing photos into narrated video walkthroughs that wow buyers.</p>
        <p class="text-sm text-indigo-600 font-sans font-medium">Show more. Sell faster.</p>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-16">
      <div class="bg-gradient-to-r from-slate-700 to-slate-600 rounded-2xl p-8 text-brand-primary">
        <h3 class="text-2xl lg:text-3xl font-display font-bold mb-4">
          Ready to Transform Your Real Estate Business?
        </h3>
        <p class="text-lg font-serif mb-6 opacity-90">
          Start with ShowSmart™ beta and be first in line for the complete AI toolkit.
        </p>
        <a href="#beta-signup" class="bg-brand-primary text-slate-700 px-8 py-3 rounded-lg font-sans font-semibold hover:bg-cream-200 transition-colors inline-block">
          Join the Beta Program
        </a>
      </div>
    </div>
  </div>
</section>
